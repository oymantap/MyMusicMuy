<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_margin="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚀 Panduan Pengguna Muy"
        android:textColor="#00E5FF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="14dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:fadeScrollbars="false">

        <TextView
            android:id="@+id/tvHelpContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.3"/>
    </ScrollView>

    <Button
        android:id="@+id/btnDismissHelp"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="16dp"
        android:text="Mengerti"
        android:textColor="#121214"
        android:textStyle="bold"
        android:backgroundTint="#00E5FF"
        app:cornerRadius="8dp"/>
</LinearLayout>
